# ===== דוגמה להגדרות סביבה של צד הלקוח (React / Vite) =====
# שלבי שימוש:
# 1. העתק קובץ זה לקובץ בשם .env  (Copy-Item .env.example .env)
# 2. עדכן את הערכים לפי הסביבה שלך
# שים לב: ב-Vite כל משתנה סביבה שצריך להגיע ל-React חייב להתחיל ב-VITE_

# כתובת הבסיס של שרת ה-API בפייתון (FastAPI).
# כברירת מחדל השרת רץ על הפורט 8000.
VITE_API_URL=http://localhost:8000

# (אופציונלי) מפתח Google Maps לצד הלקוח - לשימוש עתידי בהשלמת כתובות / מפה.
# אם משאירים ריק, הטופס יעבוד עם הזנה ידנית של קואורדינטות + כפתור "מיקום נוכחי".
VITE_GOOGLE_MAPS_API_KEY=
