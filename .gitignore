# קבצים ותיקיות שאסור לדחוף ל-Git

# תלויות שמותקנות מ-npm (גדול מאוד - מותקן מחדש עם npm install)
node_modules/

# תוצרי בנייה לייצור
dist/
dist-ssr/

# קבצי סביבה עם סודות (מפתחות API וכו') - אסור לחשוף!
.env
.env.local
.env.*.local

# לוגים
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# קבצי עורך / מערכת הפעלה
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# קבצי קאש של Python (עבור תיקיית python-service)
__pycache__/
*.pyc
venv/
